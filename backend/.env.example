# Local mode (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
REZAA_READ_ONLY=1
REZAA_ALLOWED_PATHS=~/Desktop
REZAA_CORS_ORIGINS=http://localhost:3000
